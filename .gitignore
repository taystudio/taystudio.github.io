# 운영자 전용 스크립트 (백업·도메인 migrate·sitemap 빌드·IndexNow ping 등 로컬 도구)
# IndexNow KEY 는 robots.txt 에 어차피 public — 비밀 아님. 단지 production 에 불필요.
scripts/

# 실험 sandbox (noindex prototypes — public 배포 X, 백업 repo 엔 보존)
analysis/

# 2026-05-30: blog 런칭 준비 — source·tooling·운영노트만 개별 ignore.
# 빌드 결과물(HTML·assets·data/*.json) 만 public repo 에 publish.
# 백업(taystudio-src, private) 에는 admin 포함 전체 그대로 보관됨.
#
# 통째 ignore 해제 (런칭 시 아래 한 줄 주석 처리):
#blog/
blog_back/

# ── blog 내부 — production 배포 제외 (각 패턴은 별도 라인. trailing 주석은 git 이 패턴의 일부로 해석함) ──

# md 원본 (글·페이지·초안 — 빌드 INPUT, runtime 무관)
blog/_source/
# (옛 위치 호환) 초안
blog/_drafts/
blog/_templates/
# build.py · dev-server.py — 빌드/dev 도구
blog/scripts/
# 관리자 UI — 로컬 전용. admin/index.html 만 deploy (외부 403 가드 페이지로 작동),
# 나머지 .js·write·settings 등은 ignore (source code 자체 노출 안 함).
# (negation `!` 는 부모 폴더 ignore 상태에선 안 먹어서, 명시 ignore 패턴으로 분리.)
blog/admin/*.js
blog/admin/write/
blog/admin/settings/
blog/admin/edit/
blog/admin/posting-todo/
# 운영·troubleshooting 노트
blog/plan/
# 글감 백로그
blog/posting-todo/
# (옛 위치 호환) 운영 troubleshooting
blog/troubleshooting/
# 운영 가이드 (operator 전용)
blog/guide/

# (유지) blog/data/ 와 blog/assets/ 는 publish 필수 —
#   sidebar.js·category-posts.js 가 site.json·posts(.en).json·embeds.json 을 runtime fetch.
#   assets 안의 style.css·script.js·이미지·embeds 썸네일도 HTML 이 직접 참조.

# 이미지 압축 전 원본 백업 — 로컬 롤백용, public 에 안 올림
*.bak

# dist/ — 임시 build 결과물 (publish 전 검증용)
dist/

# 게임·prototype — TAYSTUDIO 본 사이트와 분리 (별 사이트로 운영 또는 추후 통합 결정)
games/

# JS 난독화 — 원본 source 는 private backup 만 (난독화된 .js 만 public)
*.src.js

# 세션 인계 문서 (내부용 — private backup 만)
handsover.md

# 내부 리서치 문서 (비공개)
survey/

# Cloudflare Worker 소스 (애널리틱스) — wrangler로 배포, public 사이트엔 안 올림(opsec)
workers/
